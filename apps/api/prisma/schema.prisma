generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model District {
  id         String   @id @default(cuid())
  provinceId String
  code       String   @unique
  name       String
  createdAt  DateTime @default(now())

  province  Province   @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  buildings Building[]

  @@unique([provinceId, name])
  @@index([provinceId, name])
}

model Province {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String   @unique
  createdAt DateTime @default(now())

  districts District[]
}

model Building {
  id         String      @id @default(cuid())
  districtId String
  siteNumber Int
  code       String
  name       String
  slug       String      @unique
  status     DeviceState @default(ONLINE)
  createdAt  DateTime    @default(now())

  district   District    @relation(fields: [districtId], references: [id])
  blocks     Block[]
  apartments Apartment[]
  units      Unit[]
  users      User[]      @relation("BuildingUsers")
  concierges User[]      @relation("ConciergeBuildings")
  logs       GuestLog[]
  qrPasses   QrPass[]
  doorDevice DoorDevice?

  @@unique([districtId, siteNumber])
  @@index([createdAt])
  @@index([districtId, name])
}

model Block {
  id         String   @id @default(cuid())
  buildingId String
  sequence   Int
  name       String
  floorCount Int
  createdAt  DateTime @default(now())

  building   Building     @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  apartments Apartment[]
  units      Unit[]

  @@unique([buildingId, sequence])
  @@unique([buildingId, name])
}

model Apartment {
  id                String    @id @default(cuid())
  buildingId        String
  blockId           String
  sequence          Int
  name              String
  code              String    @unique
  floorCount        Int
  temporaryPassword String?
  passwordHash      String?
  passwordChangedAt DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  block    Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)
  units    Unit[]

  @@unique([blockId, sequence])
  @@unique([blockId, name])
  @@index([buildingId, code])
  @@index([buildingId, blockId])
}

model Unit {
  id          String   @id @default(cuid())
  buildingId  String
  blockId     String
  apartmentId String?
  floorNumber Int
  number      Int
  code        String   @unique
  label       String?
  ownerName   String?
  isVacant    Boolean  @default(false)

  building  Building   @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  block     Block      @relation(fields: [blockId], references: [id], onDelete: Cascade)
  apartment Apartment? @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  residents User[]

  @@unique([apartmentId, floorNumber, number])
  @@index([buildingId, code])
  @@index([buildingId, isVacant])
  @@index([buildingId, apartmentId, isVacant])
}

model User {
  id                String    @id @default(cuid())
  buildingId        String?
  unitId            String?
  fullName          String
  phone             String    @unique
  role              UserRole  @default(RESIDENT)
  isActive          Boolean   @default(true)
  temporaryPassword String?
  passwordHash      String?
  passwordChangedAt DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())

  building          Building?  @relation("BuildingUsers", fields: [buildingId], references: [id], onDelete: Cascade)
  assignedBuildings Building[] @relation("ConciergeBuildings")
  unit              Unit?      @relation(fields: [unitId], references: [id], onDelete: SetNull)
  logs              GuestLog[]
  residentQrPasses  QrPass[]   @relation("ResidentQrPasses")
  approvedQr        QrPass[]   @relation("QrApprovedBy")

  @@index([role, isActive])
  @@index([buildingId, role])
  @@index([unitId])
}

model GuestLog {
  id          String      @id @default(cuid())
  buildingId  String
  residentId  String?
  visitorName String
  visitorType VisitorType
  status      GuestStatus @default(WAITING)
  imageUrl    String?
  createdAt   DateTime    @default(now())
  decidedAt   DateTime?

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  resident User?    @relation(fields: [residentId], references: [id], onDelete: SetNull)

  @@index([buildingId, status, createdAt])
  @@index([residentId, createdAt])
}

model QrPass {
  id           String   @id @default(cuid())
  buildingId   String
  residentId   String?
  approvedById String?
  code         String   @unique
  label        String
  expiresAt    DateTime
  maxUses      Int      @default(1)
  usedCount    Int      @default(0)
  createdAt    DateTime @default(now())

  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  resident   User?    @relation("ResidentQrPasses", fields: [residentId], references: [id], onDelete: SetNull)
  approvedBy User?    @relation("QrApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([buildingId, createdAt])
  @@index([residentId, createdAt])
}

model DoorDevice {
  id         String      @id @default(cuid())
  buildingId String      @unique
  serialNo   String      @unique
  status     DeviceState @default(ONLINE)
  lastSeenAt DateTime?
  createdAt  DateTime    @default(now())

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
}

enum UserRole {
  SUPER_ADMIN
  BUILDING_ADMIN
  CONCIERGE
  RESIDENT
}

enum GuestStatus {
  WAITING
  APPROVED
  REJECTED
  ESCALATED
}

enum VisitorType {
  GUEST
  CARGO
  COURIER
  OTHER
}

enum DeviceState {
  ONLINE
  OFFLINE
}
